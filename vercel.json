{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ais-pre-g4lzo675tog5yojgc3nsej-114535588664.us-east5.run.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "https://ais-pre-g4lzo675tog5yojgc3nsej-114535588664.us-east5.run.app/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer-when-downgrade"
        }
      ]
    }
  ]
}